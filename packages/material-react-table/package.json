{
  "name": "@novastera-oss/material-react-table",
  "version": "4.0.0",
  "description": "Material UI V9 Material React Table",
  "author": "Novastera",
  "license": "MIT",
  "keywords": [
    "material-ui",
    "mui",
    "react",
    "table",
    "datagrid"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/novastera-oss/material-react-table.git"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./locales/*": {
      "types": "./dist/locales/*.d.ts",
      "import": "./dist/locales/*.js",
      "require": "./dist/locales/*.cjs"
    }
  },
  "files": [
    "dist",
    "locales",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "lib:build": "pnpm lib:build-lib && pnpm lib:build-locales",
    "lib:build-lib": "rollup -c",
    "lib:build-locales": "node build-locales.mjs",
    "lib:dev": "rollup -c -w",
    "lint": "eslint src --ext .ts,.tsx",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/match-sorter-utils": "^8.15.1",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.13.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "highlight-words": "^1.1.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@faker-js/faker": "^9.3.0",
    "@mui/material": "^9.0.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/react": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.0",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "size-limit": "^12.1.0",
    "storybook": "10.3.6",
    "storybook-dark-mode": "^5.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.12"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.13",
    "@emotion/styled": ">=11.13",
    "@mui/material": ">=9.0",
    "@mui/icons-material": ">=9.0",
    "@mui/x-date-pickers": ">=9.0",
    "react": ">=19.0",
    "react-dom": ">=19.0"
  }
}